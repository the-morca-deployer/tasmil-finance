# AI Agents server (LangGraph/FastAPI) — agents, bridge, chat threads
# local: http://localhost:8001 | prod: https://ai.tasmil-finance.xyz
NEXT_PUBLIC_AI_URL=https://ai.tasmil-finance.xyz

# NestJS backend — farming, rebalance, portfolio, auth, waitlist
# local: http://localhost:6756 | prod: https://backend.tasmil-finance.xyz
NEXT_PUBLIC_BACKEND_URL=https://backend.tasmil-finance.xyz

# Node Environment
NODE_ENV=development

# Stellar
# Use "Public Global Stellar Network ; September 2015" and "PUBLIC" for mainnet
NEXT_PUBLIC_STELLAR_NETWORK=TESTNET
NEXT_PUBLIC_STELLAR_TESTNET=true
NEXT_PUBLIC_STELLAR_PASSPHRASE="Test SDF Network ; September 2015"

# Stellar MCP direct REST API — local: http://localhost:3009 | docker: http://host.docker.internal:3009
# Only used for execute/submit/trustline. Quote + token registry use Next.js API routes directly.
NEXT_PUBLIC_MCP_STELLAR_URL=http://localhost:3009

# Tasmil Adapter SDK — server-side vars for /api/aggregator/quote and /api/tokens routes
# Network auto-detected from NEXT_PUBLIC_STELLAR_NETWORK (testnet/mainnet)
# Testnet:
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
# Mainnet (uncomment for production):
# STELLAR_RPC_URL=https://mainnet.sorobanrpc.com
# STELLAR_HORIZON_URL=https://horizon.stellar.org

# Soroswap API keys (server-side only, comma-separated for round-robin rotation)
# Get keys from https://api.soroswap.finance
SOROSWAP_API_KEYS=


# Google Analytics (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
