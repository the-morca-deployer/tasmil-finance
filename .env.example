# AI Agents server (LangGraph/FastAPI) — agents, bridge, chat threads
# local: http://localhost:8001 | prod: https://ai.tasmil-finance.xyz
NEXT_PUBLIC_AI_URL=https://ai.tasmil-finance.xyz

# NestJS backend — farming, rebalance, portfolio, auth, waitlist
# local: http://localhost:6756 | prod: https://backend.tasmil-finance.xyz
NEXT_PUBLIC_BACKEND_URL=https://backend.tasmil-finance.xyz

# Node Environment
NEXT_PUBLIC_APP_ENV=development

# Stellar Network — testnet | mainnet
NEXT_PUBLIC_STELLAR_NETWORK=testnet

# Wallet Connect — get project ID from https://cloud.reown.com
NEXT_PUBLIC_REOWN_PROJECT_ID=

# Soroswap API keys (server-side only, comma-separated for round-robin rotation)
# Get keys from https://api.soroswap.finance
SOROSWAP_API_KEYS=

# Google Analytics (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Service Worker image cache (Phase 5) — true in production docker, false in dev
# When true, registers /sw-images.js to cache token icons (cache-first, 1yr) and
# protocol assets (stale-while-revalidate, 30d) from the CDN. Off in dev to
# avoid stale-asset confusion. Override at runtime via
# window.__NEXT_PUBLIC_ENABLE_SW_CACHE_OVERRIDE__ for Playwright e2e.
NEXT_PUBLIC_ENABLE_SW_CACHE=false

# Layout chrome (Sub-Project E)
# When "true", desktop renders TopNavBar instead of AppSidebar.
# Phase 1 default is "false". Will flip to "true" in Phase 2.
NEXT_PUBLIC_USE_TOP_NAV=true
